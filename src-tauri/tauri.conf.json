{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Code Crime Scene",
  "version": "0.1.0",
  "identifier": "com.mhmds.code-crime-scene",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Code Crime Scene",
        "width": 1280,
        "height": 832,
        "minWidth": 1040,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "theme": "Dark",
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
